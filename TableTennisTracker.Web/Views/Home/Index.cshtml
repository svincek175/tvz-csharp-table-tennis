@model DashboardViewModel
@{
    ViewData["Title"] = "Home";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/") };
}

<style>
    .dashboard-header {
        text-align: center;
        margin-bottom: 48px;
    }

    .dashboard-header h1 {
        font-size: 3rem;
        font-weight: 700;
        background: linear-gradient(120deg, #ffd700, #ffed4e);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 12px;
        text-shadow: 0 0 30px rgba(255, 215, 0, 0.2);
    }

    .dashboard-header p {
        font-size: 1.1rem;
        color: #b0b0ff;
        letter-spacing: 0.5px;
    }

    /* FEATURED QUIZ CARD */
    .quiz-hero {
        background: linear-gradient(135deg, rgba(255, 20, 147, 0.15) 0%, rgba(220, 20, 60, 0.1) 100%);
        border: 2px solid rgba(255, 20, 147, 0.4);
        border-radius: 20px;
        padding: 40px;
        margin-bottom: 48px;
        text-align: center;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
        position: relative;
        overflow: hidden;
    }

    @@keyframes shimmer {
        0%, 100% { transform: translate(0, 0); }
        50% { transform: translate(50px, 50px); }
    }

    .quiz-hero:hover {
        transform: translateY(-12px) scale(1.02);
        border-color: rgba(255, 20, 147, 0.8);
        box-shadow: 0 20px 60px rgba(255, 20, 147, 0.3);
    }

    .quiz-hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .quiz-hero h2 {
        font-size: 2.2rem;
        color: #ffed4e;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        white-space: nowrap;
    }

    .quiz-hero p {
        font-size: 1rem;
        color: #d0d0ff;
        margin-bottom: 20px;
    }

    .quiz-cta {
        display: inline-block;
        background: linear-gradient(120deg, #ff1493, #ff69b4);
        color: #fff;
        padding: 14px 32px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .quiz-cta:hover {
        transform: scale(1.08);
        box-shadow: 0 10px 25px rgba(255, 20, 147, 0.4);
    }

    /* ENTITY CARDS GRID */
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-bottom: 40px;
        grid-auto-flow: dense;
    }

    .entity-card {
        background: rgba(255, 255, 255, 0.05);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 28px;
        text-decoration: none;
        color: #fff;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 220px;
    }

    .entity-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 215, 0, 0.1), transparent);
        transition: left 0.5s ease;
    }

    .entity-card:hover::before {
        left: 100%;
    }

    .entity-card:hover {
        transform: translateY(-8px);
        border-color: var(--accent-color);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    }

    .entity-card.tournaments { --accent-color: #ffb700; }
    .entity-card.venues { --accent-color: #a0a0a0; }
    .entity-card.players { --accent-color: #00d4d4; }
    .entity-card.matches { --accent-color: #ff6464; }
    .entity-card.registrations { --accent-color: #00ff88; }
    .entity-card.matchparticipants { --accent-color: #b366ff; }
    .entity-card.matchsetresults { --accent-color: #ffaa00; }

    .entity-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 16px;
        position: relative;
        z-index: 1;
    }

    .entity-icon {
        font-size: 2.4rem;
    }

    .entity-count {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--accent-color);
    }

    .entity-name {
        font-size: 1.2rem;
        font-weight: 600;
        margin-bottom: 8px;
        position: relative;
        z-index: 1;
    }

    .entity-label {
        font-size: 0.85rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        position: relative;
        z-index: 1;
    }

    .entity-latest {
        font-size: 0.9rem;
        color: #b0b0b0;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        position: relative;
        z-index: 1;
    }

    .entity-latest-value {
        color: var(--accent-color);
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .dashboard-header h1 {
            font-size: 2.2rem;
        }

        .quiz-hero {
            padding: 28px;
        }

        .quiz-hero h2 {
            font-size: 1.6rem;
        }

        .dashboard-grid {
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .entity-card {
            min-height: auto;
            padding: 20px;
        }
    }
</style>

<div class="dashboard-header">
    <h1>Tournament Tracker Dashboard</h1>
    <p>Manage all aspects of your table tennis tournaments</p>
</div>

<!-- FEATURED QUIZ CARD -->
<div class="quiz-hero">
    <div class="quiz-hero-content">
        <h2>🧠 Quiz Master</h2>
        <p>Test your knowledge about tournaments, rules, and players</p>
        <a href="/Quiz">
            <button class="quiz-cta">Start Quiz →</button>
        </a>
    </div>
</div>

<!-- ENTITY CARDS GRID -->
<div class="dashboard-grid">
    <a href="/Tournaments" class="entity-card tournaments">
        <div class="entity-card-header">
            <div class="entity-icon">🏆</div>
            <div class="entity-count">@Model.TournamentCount</div>
        </div>
        <div>
            <div class="entity-name">Tournaments</div>
            <div class="entity-label">Event Management</div>
            @if (!string.IsNullOrEmpty(Model.LatestTournament))
            {
                <div class="entity-latest">Latest: <span class="entity-latest-value">@Model.LatestTournament</span></div>
            }
        </div>
    </a>

    <a href="/Venues" class="entity-card venues">
        <div class="entity-card-header">
            <div class="entity-icon">🏢</div>
            <div class="entity-count">@Model.VenueCount</div>
        </div>
        <div>
            <div class="entity-name">Venues</div>
            <div class="entity-label">Locations & Facilities</div>
            @if (!string.IsNullOrEmpty(Model.LatestVenue))
            {
                <div class="entity-latest">Latest: <span class="entity-latest-value">@Model.LatestVenue</span></div>
            }
        </div>
    </a>

    <a href="/Players" class="entity-card players">
        <div class="entity-card-header">
            <div class="entity-icon">👥</div>
            <div class="entity-count">@Model.PlayerCount</div>
        </div>
        <div>
            <div class="entity-name">Players</div>
            <div class="entity-label">Athlete Database</div>
            <div class="entity-latest">Active: <span class="entity-latest-value">@Model.PlayerCount</span></div>
        </div>
    </a>

    <a href="/Matches" class="entity-card matches">
        <div class="entity-card-header">
            <div class="entity-icon">⚔️</div>
            <div class="entity-count">@Model.MatchCount</div>
        </div>
        <div>
            <div class="entity-name">Matches</div>
            <div class="entity-label">Games & Scoring</div>
            <div class="entity-latest">Total: <span class="entity-latest-value">@Model.MatchCount</span></div>
        </div>
    </a>

    <a href="/Registrations" class="entity-card registrations">
        <div class="entity-card-header">
            <div class="entity-icon">📋</div>
            <div class="entity-count">@Model.RegistrationCount</div>
        </div>
        <div>
            <div class="entity-name">Registrations</div>
            <div class="entity-label">Tournament Sign-ups</div>
            <div class="entity-latest">Total: <span class="entity-latest-value">@Model.RegistrationCount</span></div>
        </div>
    </a>

    <a href="/MatchParticipants" class="entity-card matchparticipants">
        <div class="entity-card-header">
            <div class="entity-icon">🎯</div>
            <div class="entity-count">@Model.MatchParticipantCount</div>
        </div>
        <div>
            <div class="entity-name">Participants</div>
            <div class="entity-label">Match Assignments</div>
            <div class="entity-latest">Total: <span class="entity-latest-value">@Model.MatchParticipantCount</span></div>
        </div>
    </a>

    <a href="/MatchSetResults" class="entity-card matchsetresults">
        <div class="entity-card-header">
            <div class="entity-icon">📊</div>
            <div class="entity-count">@Model.MatchSetResultCount</div>
        </div>
        <div>
            <div class="entity-name">Set Results</div>
            <div class="entity-label">Score Tracking</div>
            <div class="entity-latest">Total: <span class="entity-latest-value">@Model.MatchSetResultCount</span></div>
        </div>
    </a>
</div>
