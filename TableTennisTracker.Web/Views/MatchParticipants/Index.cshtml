@model IEnumerable<TableTennisTracker.Domain.Models.MatchParticipant>

@{
    ViewData["Title"] = "Match Participants";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Participants", "/MatchParticipants") };
}

<div class="index-container">
    <h1>👫 Match Participants</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Match ID</th>
                <th>Player</th>
                <th>Slot</th>
                <th>Sets Won</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var participant in Model)
            {
                <tr>
                    <td>@participant.MatchId</td>
                    <td><strong>@(participant.Player is not null ? $"{participant.Player.FirstName} {participant.Player.LastName}" : "—")</strong></td>
                    <td>@participant.Slot</td>
                    <td>@participant.ScoreSetsWon</td>
                    <td><a href="/MatchParticipants/Details/@participant.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
