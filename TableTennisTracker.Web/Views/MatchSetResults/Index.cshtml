@model IEnumerable<TableTennisTracker.Domain.Models.MatchSetResult>

@{
    ViewData["Title"] = "Match Set Results";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Set Results", "/MatchSetResults") };
}

<div class="index-container">
    <h1>📊 Match Set Results</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Match ID</th>
                <th>Set #</th>
                <th>Player 1 Points</th>
                <th>Player 2 Points</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var setResult in Model)
            {
                <tr>
                    <td>@setResult.MatchId</td>
                    <td>@setResult.SetNumber</td>
                    <td><strong>@setResult.PlayerOnePoints</strong></td>
                    <td><strong>@setResult.PlayerTwoPoints</strong></td>
                    <td><a href="/MatchSetResults/Details/@setResult.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
