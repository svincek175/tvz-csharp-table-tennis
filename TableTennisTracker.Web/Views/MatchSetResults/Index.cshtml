@model IEnumerable<TableTennisTracker.Domain.Models.MatchSetResult>

@{
    ViewData["Title"] = "Match Set Results";
}

<div style="padding: 20px;">
    <h1>📊 Match Set Results</h1>
    
    <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
        <thead style="background-color: #f5f5f5;">
            <tr>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Match ID</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Set #</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Player 1 Points</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Player 2 Points</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var setResult in Model)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px; border: 1px solid #ddd;">@setResult.MatchId.ToString().Substring(0, 8)...</td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@setResult.SetNumber</td>
                    <td style="padding: 10px; border: 1px solid #ddd;"><strong>@setResult.PlayerOnePoints</strong></td>
                    <td style="padding: 10px; border: 1px solid #ddd;"><strong>@setResult.PlayerTwoPoints</strong></td>
                </tr>
            }
        </tbody>
    </table>
</div>
