@model IEnumerable<TableTennisTracker.Domain.Models.Match>

@{
    ViewData["Title"] = "Matches";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Matches", "/Matches") };
}

<div class="index-container">
    <h1>🎾 Matches</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Round</th>
                <th>Table</th>
                <th>Scheduled Start</th>
                <th>Actual Start</th>
                <th>Completed</th>
                <th>Status</th>
                <th>Best Of</th>
                <th>Winner</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var match in Model)
            {
                <tr>
                    <td>@match.RoundNumber</td>
                    <td>@match.TableNumber</td>
                    <td>@match.ScheduledStartUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(match.ActualStartUtc.HasValue ? match.ActualStartUtc.Value.ToString("yyyy-MM-dd HH:mm") : "—")</td>
                    <td>@(match.CompletedUtc.HasValue ? match.CompletedUtc.Value.ToString("yyyy-MM-dd HH:mm") : "—")</td>
                    <td><strong>@match.Status</strong></td>
                    <td>@match.BestOfSets</td>
                    <td>@(match.WinnerPlayer is not null ? $"{match.WinnerPlayer.FirstName} {match.WinnerPlayer.LastName}" : "—")</td>
                    <td><a href="/Matches/Details/@match.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
