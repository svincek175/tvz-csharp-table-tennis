@model IEnumerable<TableTennisTracker.Domain.Models.Player>

@{
    ViewData["Title"] = "Players";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Players", "/Players") };
}

<div class="index-container">
    <h1>👥 Players</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Date of Birth</th>
                <th>Country</th>
                <th>Ranking Points</th>
                <th>Active</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in Model)
            {
                <tr>
                    <td>@player.FirstName</td>
                    <td><strong>@player.LastName</strong></td>
                    <td>@player.DateOfBirth</td>
                    <td>@player.CountryCode</td>
                    <td>@player.CurrentRankingPoints pts</td>
                    <td>@(player.IsActive ? "✓ Yes" : "✗ No")</td>
                    <td>@player.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td><a href="/Players/Details/@player.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
