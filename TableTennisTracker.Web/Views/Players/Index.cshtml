@model IEnumerable<TableTennisTracker.Domain.Models.Player>

@{
    ViewData["Title"] = "Players";
}

<div style="padding: 20px;">
    <h1>👥 Players</h1>
    
    <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
        <thead style="background-color: #f5f5f5;">
            <tr>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">First Name</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Last Name</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Date of Birth</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Country</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Ranking Points</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Active</th>
                <th style="padding: 10px; border: 1px solid #ddd; text-align: left;">Created</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var player in Model)
            {
                <tr style="border-bottom: 1px solid #ddd;">
                    <td style="padding: 10px; border: 1px solid #ddd;">@player.FirstName</td>
                    <td style="padding: 10px; border: 1px solid #ddd;"><strong>@player.LastName</strong></td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@player.DateOfBirth</td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@player.CountryCode</td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@player.CurrentRankingPoints pts</td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@(player.IsActive ? "✓ Yes" : "✗ No")</td>
                    <td style="padding: 10px; border: 1px solid #ddd;">@player.CreatedUtc:g</td>
                </tr>
            }
        </tbody>
    </table>
</div>
