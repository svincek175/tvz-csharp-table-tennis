@model IEnumerable<TableTennisTracker.Domain.Models.Registration>

@{
    ViewData["Title"] = "Registrations";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Registrations", "/Registrations") };
}

<div class="index-container">
    <h1>📋 Registrations</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Tournament</th>
                <th>Player</th>
                <th>Seed #</th>
                <th>Registered</th>
                <th>Checked In</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var registration in Model)
            {
                <tr>
                    <td>@registration.Tournament?.Name</td>
                    <td><strong>@(registration.Player is not null ? $"{registration.Player.FirstName} {registration.Player.LastName}" : "—")</strong></td>
                    <td>@registration.SeedNumber</td>
                    <td>@registration.RegisteredUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@(registration.IsCheckedIn ? "✓ Yes" : "✗ No")</td>
                    <td><a href="/Registrations/Details/@registration.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
