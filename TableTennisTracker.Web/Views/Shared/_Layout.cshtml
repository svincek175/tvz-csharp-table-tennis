<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Table Tennis Tracker</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #1a1a2e 0%, #0f1624 100%);
            color: #fff;
            min-height: 100vh;
        }

        .app-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 0;
            min-height: 100vh;
        }

        /* SIDEBAR NAVIGATION */
        .sidebar {
            background: rgba(20, 20, 35, 0.95);
            border-right: 2px solid rgba(255, 215, 0, 0.2);
            padding: 32px 20px;
            overflow-y: auto;
            position: fixed;
            left: 0;
            width: 250px;
            height: 100vh;
            backdrop-filter: blur(10px);
        }

        .sidebar-header {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 32px;
            padding-bottom: 16px;
            border-bottom: 2px solid rgba(255, 215, 0, 0.3);
            background: linear-gradient(120deg, #ffd700, #ffed4e);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
        }

        .nav-section {
            margin-bottom: 28px;
        }

        .nav-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #888;
            margin-bottom: 12px;
            font-weight: 600;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 10px;
            text-decoration: none;
            color: #b0b0ff;
            font-weight: 500;
            transition: all 0.3s ease;
            margin-bottom: 8px;
            border: 2px solid transparent;
            cursor: pointer;
            width: 100%;
            box-sizing: border-box;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 215, 0, 0.3);
            color: #fff;
            transform: translateX(4px);
        }

        .nav-link.active {
            background: rgba(255, 215, 0, 0.15);
            border-color: #ffd700;
            color: #ffed4e;
        }

        .nav-link.quiz {
            background: rgba(182, 102, 255, 0.1);
            border-color: rgba(182, 102, 255, 0.4);
        }

        .nav-link.quiz:hover {
            background: rgba(182, 102, 255, 0.2);
            border-color: rgba(182, 102, 255, 0.6);
            color: #d9a7ff;
        }

        .nav-icon {
            font-size: 1.3rem;
            width: 28px;
            text-align: center;
        }

        /* MAIN CONTENT */
        .main-wrapper {
            margin-left: 250px;
            overflow-y: auto;
            width: calc(100% - 250px);
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* BREADCRUMB */
        .breadcrumb-container {
            position: sticky;
            top: 0;
            z-index: 100;
            padding: 16px 48px;
            margin-bottom: 24px;
            background: rgba(20, 20, 35, 0.9);
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
            border-radius: 0;
            backdrop-filter: blur(10px);
            flex-shrink: 0;
        }

        .content {
            padding: 32px 48px;
            flex: 1;
            width: 100%;
            box-sizing: border-box;
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
            font-size: 0.95rem;
        }

        .breadcrumb-item {
            color: #b0b0ff;
            text-decoration: none;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: 6px;
            transition: all 0.3s ease;
        }

        .breadcrumb-item:hover {
            background: rgba(255, 215, 0, 0.1);
            color: #ffed4e;
        }

        .breadcrumb-item.active {
            color: #ffed4e;
            font-weight: 600;
            cursor: default;
        }

        .breadcrumb-separator {
            color: #666;
            font-weight: 300;
        }

        /* MAIN CONTENT */
        .content {
            background: transparent;
            border-radius: 16px;
        }

        /* RESPONSIVE */
        @@media (max-width: 1024px) {
            .app-container {
                grid-template-columns: 1fr;
            }

            .sidebar {
                position: fixed;
                left: -250px;
                transition: left 0.3s ease;
                z-index: 200;
                box-shadow: 2px 0 20px rgba(0, 0, 0, 0.5);
            }

            .sidebar.open {
                left: 0;
            }

            .main-wrapper {
                margin-left: 0;
            }
        }

        @@media (max-width: 640px) {
            .breadcrumb {
                font-size: 0.85rem;
                gap: 8px;
            }

            .main-wrapper {
                padding: 16px;
            }
        }

        /* Scrollbar styling */
        .sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }

        .sidebar::-webkit-scrollbar-thumb {
            background: rgba(255, 215, 0, 0.2);
            border-radius: 10px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 215, 0, 0.4);
        }

        @@keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 20, 147, 0.4); }
            50% { box-shadow: 0 0 0 10px rgba(255, 20, 147, 0); }
        }

        .nav-link.quiz {
            animation: pulse 2s ease-in-out infinite;
        }

        /* TABLE STYLING FOR INDEX PAGES */
        .index-container {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 28px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .index-container h1 {
            color: #ffed4e;
            margin-bottom: 24px;
            font-size: 2rem;
        }

        .index-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        .index-table thead {
            background-color: rgba(255, 183, 0, 0.15);
            border-bottom: 2px solid rgba(255, 183, 0, 0.3);
        }

        .index-table th {
            padding: 12px;
            text-align: left;
            color: #ffb700;
            font-weight: 600;
        }

        .index-table td {
            padding: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            color: #d0d0ff;
        }

        .index-table tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.03);
        }

        .index-table strong {
            color: #fff;
        }

        .index-table a {
            color: #00d4d4;
            text-decoration: none;
            transition: all 0.3s ease;
            font-weight: 500;
        }

        .index-table a:hover {
            color: #ffed4e;
            text-decoration: underline;
        }

        /* DETAILS PAGE STYLING */
        .details-container {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 28px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .details-container h1 {
            color: #ffed4e;
            margin-bottom: 24px;
            font-size: 2rem;
        }

        .details-grid {
            display: grid;
            grid-template-columns: 220px 1fr;
            gap: 10px 20px;
            margin-top: 20px;
        }

        .details-grid strong {
            color: #ffb700;
            font-weight: 600;
        }

        .details-grid span {
            color: #d0d0ff;
        }

        .details-grid span a {
            color: #00d4d4;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .details-grid span a:hover {
            color: #ffed4e;
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- SIDEBAR NAVIGATION -->
        <aside class="sidebar">
            <div class="sidebar-header">
                TT Tracker
            </div>

            <nav class="nav-section">
                <div class="nav-section-title">Core Navigation</div>
                <a href="/" class="nav-link home" data-breadcrumb="Home">
                    <span class="nav-icon">🏠</span>
                    <span>Home</span>
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-title">Entities</div>
                <a href="/Tournaments" class="nav-link tournaments" data-breadcrumb="Tournaments">
                    <span class="nav-icon">🏆</span>
                    <span>Tournaments</span>
                </a>
                <a href="/Venues" class="nav-link venues" data-breadcrumb="Venues">
                    <span class="nav-icon">🏢</span>
                    <span>Venues</span>
                </a>
                <a href="/Players" class="nav-link players" data-breadcrumb="Players">
                    <span class="nav-icon">👥</span>
                    <span>Players</span>
                </a>
                <a href="/Matches" class="nav-link matches" data-breadcrumb="Matches">
                    <span class="nav-icon">⚔️</span>
                    <span>Matches</span>
                </a>
                <a href="/Registrations" class="nav-link registrations" data-breadcrumb="Registrations">
                    <span class="nav-icon">📋</span>
                    <span>Registrations</span>
                </a>
                <a href="/MatchParticipants" class="nav-link matchparticipants" data-breadcrumb="Participants">
                    <span class="nav-icon">🎯</span>
                    <span>Participants</span>
                </a>
                <a href="/MatchSetResults" class="nav-link matchsetresults" data-breadcrumb="Set Results">
                    <span class="nav-icon">📊</span>
                    <span>Set Results</span>
                </a>
            </nav>

            <nav class="nav-section">
                <div class="nav-section-title">Special Features</div>
                <a href="/Quiz" class="nav-link quiz" data-breadcrumb="Quiz">
                    <span class="nav-icon">🧠</span>
                    <span>Quiz Master</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-wrapper">
            <!-- BREADCRUMB -->
            <div class="breadcrumb-container">
                <nav class="breadcrumb">
                    @{
                        var breadcrumbs = (List<(string Label, string Url)>)ViewData["Breadcrumbs"];
                        if (breadcrumbs == null || breadcrumbs.Count == 0)
                        {
                            breadcrumbs = new List<(string, string)> { ("Home", "/") };
                        }
                    }

                    @foreach (var (i, breadcrumb) in breadcrumbs.Select((x, i) => (i, x)))
                    {
                        @if (i < breadcrumbs.Count - 1)
                        {
                            <a href="@breadcrumb.Url" class="breadcrumb-item">@breadcrumb.Label</a>
                            <span class="breadcrumb-separator">→</span>
                        }
                        else
                        {
                            <span class="breadcrumb-item active">@breadcrumb.Label</span>
                        }
                    }
                </nav>
            </div>

            <!-- PAGE CONTENT -->
            <div class="content">
                @RenderBody()
            </div>
        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Set active navigation state based on current page
        document.addEventListener("DOMContentLoaded", function() {
            const currentPath = window.location.pathname.toLowerCase();
            const navLinks = document.querySelectorAll(".nav-link");
            
            navLinks.forEach(link => {
                const href = link.getAttribute("href").toLowerCase();
                // Check if the current path matches the link (handle both exact and prefix matches)
                if (currentPath === href || currentPath.startsWith(href + "/") || 
                    (href === "/" && currentPath === "/")) {
                    link.classList.add("active");
                } else {
                    link.classList.remove("active");
                }
            });
        });
    </script>
</body>
</html>
