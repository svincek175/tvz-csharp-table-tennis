@model IEnumerable<TableTennisTracker.Domain.Models.Tournament>

@{
    ViewData["Title"] = "Tournaments";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Tournaments", "/Tournaments") };
}

<div class="index-container">
    <h1>🏆 Tournaments</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Season</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Max Players</th>
                <th>Organizer</th>
                <th>Ranking Event</th>
                <th>Venue</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tournament in Model)
            {
                <tr>
                    <td><strong>@tournament.Name</strong></td>
                    <td>@tournament.SeasonLabel</td>
                    <td>@tournament.StartUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@tournament.EndUtc.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>@tournament.MaxPlayers</td>
                    <td>@tournament.OrganizerName</td>
                    <td>@(tournament.IsRankingEvent ? "✓ Yes" : "✗ No")</td>
                    <td>@tournament.Venue?.Name</td>
                    <td>
                        <a href="/Tournaments/Details/@tournament.Id">View Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
