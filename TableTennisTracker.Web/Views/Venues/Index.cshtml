@model IEnumerable<TableTennisTracker.Domain.Models.Venue>

@{
    ViewData["Title"] = "Venues";
    ViewData["Breadcrumbs"] = new List<(string, string)> { ("Home", "/"), ("Venues", "/Venues") };
}

<div class="index-container">
    <h1>🏢 Venues</h1>

    <table class="index-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>City</th>
                <th>Country</th>
                <th>Address</th>
                <th>Tables</th>
                <th>Capacity</th>
                <th>Time Zone</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var venue in Model)
            {
                <tr>
                    <td><strong>@venue.Name</strong></td>
                    <td>@venue.City</td>
                    <td>@venue.CountryCode</td>
                    <td>@venue.AddressLine</td>
                    <td>@venue.NumberOfTables</td>
                    <td>@venue.Capacity</td>
                    <td>@venue.TimeZoneId</td>
                    <td><a href="/Venues/Details/@venue.Id">View Details</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
